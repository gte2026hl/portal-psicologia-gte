            "CIUDAD ALIANZA": ["1era Etapa 1", "1ra Etapa 2", "2da Etapa", "3ra Etapa", "4F Alianza Gardens", "4ta Etapa A", "4ta Etapa B", "5ta Etapa", "Aguamarina", "Aguasal", "Brisa del Lago", "Conjunto Residencial Villa Alianza II", "José Laurencio Silva", "Prado del Lago", "Villa Alianza 1, Casas Dignas", "Villa Alianza Viviendas Dignas", "Villas del Lago y Río Verde"],
            "SAMÁN": ["Apamates", "Bosques del Samán", "Ceiba del Samán", "El Prado", "Enmanuel", "Lagunas del Samán", "Los Girasoles del Samán", "Sector 1", "Sector 2", "Sector 3", "Sector 4", "Sector 5", "Sector 6", "Sector 7", "Sector 8", "Sector 9", "Sector 10", "Sector 11", "Sector 12", "Villas de Capreminfra"],
            "SUR": ["Amazonia", "Banco Obrero", "Cristo Salva", "La Lucha", "Lago Jardín", "Libertad 1", "Libertad 2", "Macario Escorcha", "Nueva Guacara", "Turumo 1", "Turumo 2", "Villa Guacara"],
            "TOCO": ["Cardonal 1", "Cardonal 2", "La Alegría", "La Emboscada", "La Floresta Norte", "Los Caobos", "Los Naranjos Norte", "Negro Primero", "Perrote 1", "Perrote 2", "Perrote 3", "Perrote 4", "San Rafael", "Simón Bolívar Norte", "Toco Norte", "Toquito La Milagrosa", "Urb. La Emboscada", "Urb. Las Brisas", "Valles de Naranjal", "Victoria de Guacara", "Villa Tarento"],
            "VIGIRIMA": ["Avispero Norte", "Bolivariano I", "Bolivariano II", "Brisas del Mayei", "Cacho Mocho", "Colinas de Tronconero", "Colinas del Toco Ojo de Agua", "Diego Ibarra", "El Chaparral", "El Sisal", "Flor de la Manga", "La Compañía", "La Morita", "La Vecindad", "Mata Redonda", "Peñita Agrícola", "Peñita el Viento", "Petroglifos de Ojo de Agua", "Ramón Cruces", "Tronconero", "Tronconero Norte", "Tronconero Sur", "Valle Dorado", "Valles de Vigirima", "Vigirima Centro", "Villas del Toco"],
            "YAGUA": ["Araguaney II A", "Araguaney II B", "Araguaney Primero", "Campo Amor", "El Cabrito", "El Limón", "El Naranjal", "El Porvenir", "La Manga", "La Milagrosa", "La Primavera", "Las Malvinas", "Las Mandarinas", "Los Almendrones", "Los Cedros", "Los Girasoles de Yagua", "Los Mangos", "Los Merecures", "Los Naranjos", "Maracaibero", "Quebrada Honda", "Samán Azucena", "San Esteban", "Valles de Yagua"]
        };

        function cargarSectores() {
            const t = document.getElementById('reg-territorio').value, s = document.getElementById('reg-sector');
            s.innerHTML = '<option value="">Seleccione Sector...</option>';
            if (t && sectoresData[t]) { s.disabled = false; sectoresData[t].forEach(sec => { let opt = document.createElement('option'); opt.value = sec; opt.innerHTML = sec; s.appendChild(opt); }); } 
            else { s.disabled = true; }
        }

        window.onload = async () => {
            const { data: { session } } = await _supabase.auth.getSession();
            if (session) {
                const { data: per } = await _supabase.from('usuarios').select('*').eq('id', session.user.id);
                if (per && per.length) { usuarioActual = per[0]; iniciarApp(); }
            }
        };

        function togglePassword() { const i = document.getElementById('login-pass'); i.type = i.type === "password" ? "text" : "password"; }
        function animarCarga(p) { const b = document.getElementById('loading-bar'); const c = document.getElementById('loading-bar-container'); c.style.display = 'block'; b.style.width = p + '%'; if (p >= 100) setTimeout(() => c.style.display = 'none', 800); }

        async function ejecutarLogin() {
            const e = document.getElementById('login-email').value, p = document.getElementById('login-pass').value;
            const { data: { user }, error } = await _supabase.auth.signInWithPassword({ email: e, password: p });
            if (error) return alert("Acceso Denegado");
            const { data: per } = await _supabase.from('usuarios').select('*').eq('id', user.id);
            usuarioActual = per[0]; iniciarApp();
        }

        function iniciarApp() {
            document.getElementById('login-screen').classList.add('hidden'); document.getElementById('sidebar').classList.remove('hidden'); document.getElementById('main-content').classList.remove('hidden'); document.getElementById('display-user-name').innerText = usuarioActual.nombre;
            document.getElementById('display-user-rol').innerText = "ACCESO: " + usuarioActual.rol;
            const menu = document.getElementById('nav-menu');
            if (usuarioActual.rol === 'MASTER') {
                document.getElementById('master-only-upload').classList.remove('hidden');
                menu.innerHTML = `<button onclick="cambiarTab('tab-master-stats')" class="nav-button active">📊 Estadísticas</button><button onclick="cambiarTab('tab-repositorio')" class="nav-button">📁 Repositorio Maestro</button>`;
            } else {
                menu.innerHTML = `<button onclick="cambiarTab('tab-repositorio')" class="nav-button active">📁 Repositorio Maestro</button><button onclick="cambiarTab('tab-mis-pacientes')" class="nav-button">💼 Mis Pacientes</button>`;
            }
            cargarExpedientes();
        }

        // --- ARQUITECTURA RECURSIVA PRESERVADA (NIEVES) ---
        async function cargarExpedientes() {
            let all = [], from = 0, to = 999, done = false;
            while (!done) {
                const { data } = await _supabase.from('expedientes').select('*').order('id_gte', { ascending: true }).range(from, to);
                if (!data || data.length === 0) done = true;
                else { all = all.concat(data); if (data.length < 1000) done = true; else { from += 1000; to += 1000; } }
            }
            todosLosExpedientes = all;
            renderizarTabla(todosLosExpedientes);
            if(usuarioActual.rol === 'MASTER') cargarEstadisticas(todosLosExpedientes);
            if(document.getElementById('tab-mis-pacientes').style.display !== 'none') renderizarMisPacientes();
        }

        // --- PETICIÓN NIEVES: ESTADÍSTICAS POR SECTOR (REEMPLAZA INSTITUCIONES) ---
        async function cargarEstadisticas(data) {
            const peso = { "1ra Cita": 1, "2da Cita": 2, "3ra Cita": 3, "4ta Cita": 4, "Alta Psicológica": 4, "Derivación (SMPNNA)": 1 };
            const citas = data.reduce((acc, x) => acc + (peso[x.seguimiento] || 0), 0);
            const psicos = new Set(data.filter(x => x.psico_asignado_id).map(x => x.psico_asignado_id)).size;
            const derivaciones = data.filter(x => x.seguimiento === "Derivación (SMPNNA)").length;

            const kpis = [
                { t: "Expedientes", v: data.length, c: "text-gte-blue" },
                { t: "Impacto (Citas)", v: citas, c: "text-gte-orange" },
                { t: "Especialistas", v: psicos, c: "text-blue-500" },
                { t: "Derivaciones SMPNNA", v: derivaciones, c: "text-purple-600" },
                { t: "Fase 3", v: data.filter(x => x.fase_actual == "3").length, c: "text-red-600" },
                { t: "Fase 2", v: data.filter(x => x.fase_actual == "2").length, c: "text-yellow-600" }
            ];

            document.getElementById('kpi-grid').innerHTML = kpis.map(s => `<div class="bg-white p-6 rounded-[25px] border border-slate-100 shadow-sm text-center"><p class="text-[9px] font-black text-slate-400 uppercase tracking-widest">${s.t}</p><h3 class="text-3xl font-black ${s.c} mt-2">${s.v}</h3></div>`).join('');

            // --- Lógica de Sectores (Lo más exacto) ---
            const { data: socialData } = await _supabase.from('caracterizacion_social').select('sector');
            const map = {}; if(socialData) socialData.forEach(x => { if(x.sector) map[x.sector] = (map[x.sector] || 0) + 1; });
            const labels = Object.keys(map).sort((a,b) => map[b] - map[a]).slice(0, 10);
            
            if(chartInst) chartInst.destroy();
            chartInst = new Chart(document.getElementById('chartInstituciones').getContext('2d'), { 
                type: 'bar', data: { labels, datasets: [{ label: 'Casos Reales', data: labels.map(l => map[l]), backgroundColor: '#FFD700', borderRadius: 5 }] }, 
                options: { indexAxis: 'y', maintainAspectRatio: false, plugins: { legend: { display: false } } } 
            });
        }

        async function guardarCaracterizacion() {
            animarCarga(40);
            const d = { 
                id_gte: expActivo, nombres: document.getElementById('cs-nombres').value.toUpperCase(), apellidos: document.getElementById('cs-apellidos').value.toUpperCase(), 
                sexo: document.getElementById('cs-sexo').value, fecha_nacimiento: document.getElementById('cs-fecha-nac').value, 
                telefono_contacto: document.getElementById('cs-tlf').value, sector: document.getElementById('reg-sector').value, // <--- Sector dinámico Nieves
                informante: document.getElementById('cs-informante').value, calle: document.getElementById('cs-calle').value, casa: document.getElementById('cs-casa').value,
                madre_nombre: document.getElementById('cs-m-nombre').value, padre_nombre: document.getElementById('cs-p-nombre').value
            };
            const { error } = await _supabase.from('caracterizacion_social').upsert(d, { onConflict: 'id_gte' });
            if (!error) {
                // WEBHOOK PRESERVADO
                fetch("https://script.google.com/macros/s/AKfycbyGN-u86fpo9eHW-0CF6bIeTDl8eVY5FdLwq8tRGNDwpfldt0PxGyVUfz_2JtG91FBw/exec", { method: 'POST', mode: 'no-cors', body: JSON.stringify(d) });
                document.getElementById('modal-demograficos').style.display = 'none'; document.getElementById('modal-historia').style.display = 'flex';
                animarCarga(100); lanzarToast("CARACTERIZACIÓN TERRITORIAL SINCRONIZADA");
            }
        }

        // --- ARQUITECTURA CHUNKING PRESERVADA (NIEVES) ---
        async function procesarCargaMaestra(e) {
            animarCarga(10); const file = e.target.files[0]; const reader = new FileReader();
            reader.onload = async (evt) => {
                const wb = XLSX.read(evt.target.result, { type: 'binary' }); const raw = XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]]);
                const lotes = raw.map(f => {
                    const r = {}; Object.keys(f).forEach(k => r[k.trim().toUpperCase()] = f[k]);
                    return { id_gte: String(r['EXPEDIENTE'] || '').trim(), fase_actual: String(r['FASE'] || '3').trim(), nombre_paciente: String(r['NOMBRE Y APELLIDO'] || '').trim().toUpperCase(), institucion_educativa: String(r['INSTITUCIÓN'] || '').trim().toUpperCase(), cedula_paciente: String(r['CÉDULA'] || '').trim(), edad_paciente: parseInt(r['EDAD']) || 0, seguimiento: 'Sin Iniciar' };
                }).filter(x => x.id_gte !== '');
                const SZ = 500; for (let i = 0; i < lotes.length; i += SZ) { await _supabase.from('expedientes').upsert(lotes.slice(i, i + SZ), { onConflict: 'id_gte' }); animarCarga(Math.round(((i + SZ) / lotes.length) * 100)); }
                cargarExpedientes();
            };
            reader.readAsBinaryString(file);
        }

        function renderizarTabla(datos) {
            const b = document.getElementById('lista-expedientes');
            b.innerHTML = datos.slice(0, 1000).map(exp => `
                <tr class="border-b border-slate-50"><td class="p-5 font-black text-gte-orange text-[10px]">${exp.id_gte}</td><td class="p-5 font-bold text-gte-blue uppercase text-[11px]">${exp.nombre_paciente}</td><td class="p-5 text-center font-black">${exp.fase_actual}</td><td class="p-5 text-[9px] font-black uppercase text-blue-600">${exp.seguimiento || 'Pendiente'}</td><td class="p-5 text-right">
                    ${!exp.psico_asignado_id && usuarioActual.rol === 'PSICOLOGO' ? `<button onclick="adoptarCaso('${exp.id_gte}')" class="btn-gte-orange px-4 py-2 text-[9px] uppercase">Adoptar</button>` : `<div class="text-[9px] font-bold italic text-slate-400 uppercase">${exp.psico_asignado_nombre || 'Disponible'}</div>`}
                </td></tr>`).join('');
        }

        function renderizarMisPacientes() {
            const mis = todosLosExpedientes.filter(x => x.psico_asignado_id === usuarioActual.id);
            const b = document.getElementById('lista-mis-pacientes');
            b.innerHTML = mis.map(exp => `<tr class="border-b border-slate-50"><td class="p-5 font-black text-gte-orange text-[10px]">${exp.id_gte}</td><td class="p-5 font-bold text-gte-blue uppercase text-[11px]">${exp.nombre_paciente}</td><td class="p-5 text-[10px] font-black uppercase">${exp.seguimiento}</td><td class="p-5 text-right"><button onclick="abrirAtencion('${exp.id_gte}')" class="btn-gte-orange px-4 py-2 text-[9px] uppercase">Atender</button></td></tr>`).join('');
        }

        async function guardarHistoriaClinica() {
            const d = { id_gte: expActivo, psico_id: usuarioActual.id, motivo_consulta: document.getElementById('hc-motivo').value, entrevista_notas: document.getElementById('hc-notas').value };
            await _supabase.from('historias_clinicas').insert(d); cerrarModales(); cargarExpedientes(); LanzarToast("ATENCIÓN FINALIZADA");
        }

        async function adoptarCaso(id) { await _supabase.from('expedientes').update({ psico_asignado_id: usuarioActual.id, psico_asignado_nombre: usuarioActual.nombre, seguimiento: '1ra Cita' }).eq('id_gte', id); cargarExpedientes(); }
        async function actualizarEstatus(id, val) { await _supabase.from('expedientes').update({ seguimiento: val }).eq('id_gte', id); cargarExpedientes(); }
        function cambiarTab(id) { document.querySelectorAll('.tab-content').forEach(t => t.classList.add('hidden')); document.getElementById(id).classList.remove('hidden'); }
        function cerrarModales() { document.querySelectorAll('.clinical-modal').forEach(m => m.style.display = 'none'); }
        function abrirAtencion(id) { expActivo = id; document.getElementById('modal-demograficos').style.display = 'flex'; }
        function lanzarToast(m) { const t = document.getElementById('gte-toast'); t.innerText = m; t.style.display = 'block'; setTimeout(() => t.style.display = 'none', 3000); }
        function filtrarTabla() { const b = document.getElementById('buscador-input').value.toLowerCase(); renderizarTabla(todosLosExpedientes.filter(x => x.nombre_paciente.toLowerCase().includes(b) || x.id_gte.toLowerCase().includes(b))); }
        async function cerrarSesion() { await _supabase.auth.signOut(); location.reload(); }
        function generarPDF() { html2pdf().from(document.getElementById('reporte-area')).save(); }
    </script>
</body>
</html>
