    <script>
        const SUPABASE_URL = "https://mltfjgkbparwwofgknjg.supabase.co";
        const SUPABASE_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1sdGZqZ2ticGFyd3dvZmdrbmpnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzg0MjExNTIsImV4cCI6MjA5Mzk5NzE1Mn0.LZQESe5Nvuor2apbAdhfHlCr_hBtI-pb6wTEKAK0ldU";
        const _supabase = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

        let usuarioActual = null, todosLosExpedientes = [], chartInst = null, expActivo = null;

        // --- DATA NIEVES: TERRITORIOS Y SECTORES ---
        const sectoresData = {
            "ARAGÜITA": ["13 de Mayo", "19 de Julio", "Cacique de Guacara", "Dios Todopoderoso", "El Libertador", "El Milagro", "Ezequiel Zamora", "Guaicaipuro", "Guaicaipuro Bolivariano", "José Gregorio Guitián", "Juventud 1", "Juventud 2", "La Ceiba 2", "La Ceiba 2021", "La Floresta Sur", "La Franja", "Mocundo", "Nuestra Señora de la Coromoto", "Rafael Caldera", "Santa Bárbara 1", "Santa Bárbara 2", "Santa Eduviges", "Simón Bolívar Sur", "Tesoro del Indio Lote 2", "Tesoro del Indio Lote 3", "Tricentenario"],
