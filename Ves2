            <div class="mt-10">
                <p class="text-[9px] font-bold uppercase tracking-widest leading-relaxed">
                    <span class="text-slate-300">Alcaldía de Guacara / Dirección Ejecutiva</span><br>
                    <span class="gradient-text-footer">HDC2026 — Guacara Te Escucha</span>
                </p>
            </div>
        </div>
    </div>

    <nav id="sidebar" class="hidden no-print w-full md:w-64 bg-white border-r h-screen sticky top-0 flex flex-col p-6 shadow-sm">
        <div class="mb-10 text-center">
            <h2 class="text-lg font-black text-gte-blue leading-tight uppercase">GTE<span class="text-gte-orange">2026</span></h2>
            <p id="display-user-rol" class="text-[8px] font-black text-slate-300 uppercase mt-1">ROL</p>
        </div>
        <div id="nav-menu" class="flex-grow space-y-2"></div>
        <div class="pt-6 border-t text-center">
