    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@600;700;800&family=Open+Sans:wght@400;600;700&display=swap');
        
        :root { 
            --gte-blue: #003366; 
            --gte-orange: #FF6600; 
            --gte-gold: #FFD700;
            --gte-bg: #f8fafc; 
        }

        body { font-family: 'Open Sans', sans-serif; background-color: var(--gte-bg); margin: 0; overflow-x: hidden; }
        h1, h2, h3 { font-family: 'Poppins', sans-serif; }
        
        .gradient-border { 
            border-top: 8px solid;
            border-image: linear-gradient(to right, var(--gte-gold), var(--gte-orange)) 1; 
        }

        .gradient-text-footer { 
            background: linear-gradient(to right, #b8860b, var(--gte-orange));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 800;
        }

        #loading-bar-container { 
            position: fixed; top: 0; left: 0; width: 100%; height: 4px; 
            background: rgba(226, 232, 240, 0.3); z-index: 10005; display: none; 
        }
        #loading-bar { 
            height: 100%; width: 0; 
            background: linear-gradient(to right, var(--gte-gold), var(--gte-orange)); 
            transition: width 0.4s ease; 
        }

        .btn-gte-orange { background: var(--gte-orange); color: white; font-weight: 800; border-radius: 12px; transition: 0.3s; cursor: pointer; border: none; }
        .btn-gte-orange:hover { background: var(--gte-blue); transform: translateY(-2px); }
        
        .nav-button { width: 100%; text-align: left; padding: 14px 20px; display: flex; align-items: center; gap: 10px; font-size: 11px; font-weight: 700; color: #94a3b8; transition: 0.3s; border-radius: 12px; background: transparent; border: none; cursor: pointer; }
        .nav-button.active { background: rgba(255,102,0,0.1); color: var(--gte-orange); }
        
        .form-input { width: 100%; border: 2px solid #e2e8f0; border-radius: 12px; padding: 12px; outline: none; transition: 0.3s; font-size: 13px; }
        .form-input:focus { border-color: var(--gte-orange); }
        
        .clinical-modal { position: fixed; inset: 0; background: rgba(0,51,102,0.9); backdrop-filter: blur(8px); display: none; align-items: center; justify-content: center; z-index: 10010; }

        #gte-toast { position: fixed; bottom: 20px; right: 20px; background: var(--gte-blue); color: white; padding: 15px 25px; border-radius: 10px; border-left: 5px solid var(--gte-orange); display: none; z-index: 10015; font-weight: 800; font-size: 12px; box-shadow: 0 10px 15px rgba(0,0,0,0.1); }
        
        @media print { .no-print { display: none !important; } }
    </style>
</head>
<body class="min-h-screen flex flex-col md:flex-row">

    <div id="loading-bar-container"><div id="loading-bar"></div></div>

    <div id="login-screen" class="fixed inset-0 z-[100] bg-[#003366] flex items-center justify-center p-6">
